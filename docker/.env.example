# =================================
# CONFIGURATION CENTRALISÉE DOCKER
# =================================
# Copiez ce fichier vers .env et modifiez selon vos besoins

# Versions
POSTGRES_VERSION=15
PHP_VERSION=8.2

# Ports (modifiez si vous avez des conflits)
NGINX_PORT=81
DB_DEV_PORT=5434
DB_TEST_PORT=5433

# Base de données de développement
DB_DEV_NAME=proxifix
DB_DEV_USER=postgres
DB_DEV_PASSWORD=password
DB_DEV_HOST=database

# Base de données de test
DB_TEST_NAME=cda_app_test
DB_TEST_USER=cda_app
DB_TEST_PASSWORD=password
DB_TEST_HOST=database_test

BACKEND_API_PORT=8082
# Symfony Configuration
APP_ENV=dev
KERNEL_CLASS=App\\Kernel
APP_SECRET=$ecretf0rt3st
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

# JWT Configuration (changez le passphrase en production)
JWT_PASSPHRASE=proxifix_jwt_passphrase
JWT_SECRET_KEY=/var/www/symfony/config/jwt/private.pem
JWT_PUBLIC_KEY=/var/www/symfony/config/jwt/public.pem

# Configuration Docker
PROJECT_NAME=cda_app
